{
  "name": "event-quote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && tsc --noEmit",
    "prebuild": "node scripts/check-auth-env.mjs",
    "build": "next build",
    "postbuild": "node scripts/normalize-tsconfig.mjs",
    "start": "next start",
    "verify:real-model-quality": "tsx scripts/verify-real-model-quality.ts",
    "verify:real-all-docs": "tsx scripts/verify-real-all-docs.ts",
    "verify:production-runtime": "tsx scripts/verify-production-runtime.ts",
    "test:admin-auth-security": "tsx scripts/test-admin-auth-security.ts",
    "test:ai-quality": "tsx scripts/test-ai-quality.ts",
    "test:db-fallback": "tsx scripts/test-db-fallback.ts",
    "test:e2e": "playwright test",
    "test:pdf-kind": "tsx scripts/test-pdf-export-kind.ts",
    "verify:release": "npm run typecheck && npm run build && npm run test:db-fallback && npm run test:admin-auth-security && npm run test:pdf-kind && npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tosspayments/payment-sdk": "^1.9.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "node-pptx-parser": "^1.0.1",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.2",
    "pretendard": "^1.3.9",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
