# ── NextAuth (소셜 로그인) ──
# 운영: 실제 서비스 URL과 동일하게 설정 (예: https://www.planic.cloud). 코드에서 변경하지 않음.
NEXTAUTH_URL=https://www.planic.cloud
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# 관리자 로그인(운영 필수): 미설정 시 production에서 admin 로그인이 차단됩니다.
ADMIN_PASSWORD=ChangeThisToAStrongPassword!
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
# 플래닉 전용 프로젝트에서 발급 권장. 동의 화면 앱 이름 = 플래닉/Planic (쿼닥 등 구 클라이언트와 분리 가능)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# Kakao Developers (선택)
# KAKAO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# KAKAO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Naver Developers (선택)
# NAVER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
# NAVER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# 로컬 개발 시 예시:
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=dev-secret-min-32-characters-long

# ── AI 엔진 (둘 중 하나만 있어도 됨) ──
# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# 모델 (선택). 기본값: claude-sonnet-4-6. 더 높은 품질 원하면 claude-opus-4-6
# ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# 사용할 모델 (선택, 기본값: gpt-4o)
# OPENAI_MODEL=gpt-4o

# 엔진 강제 선택 (권장): anthropic | openai
# 비용 가드레일 권장값: OpenAI 단일 경로
AI_PROVIDER=openai

# 하이브리드 파이프라인 (선택): OpenAI로 초안·재시도, Anthropic으로 품질 보정(repair)
# 켜려면 AI_PIPELINE_MODE=hybrid 이고 OPENAI·ANTHROPIC 키가 모두 있어야 합니다.
# 비용 가드레일 권장값: 기본 OFF
AI_ENABLE_HYBRID=0
# AI_PIPELINE_MODE=hybrid
# OPENAI_MODEL_DRAFT=gpt-5.4-mini
# ANTHROPIC_MODEL_REFINE=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-1-20250805
# OPENAI_MAX_TOKENS_DRAFT=2500
# ANTHROPIC_MAX_TOKENS_REFINE=4000
# PREMIUM 플랜에 ANTHROPIC_MODEL_PREMIUM 사용(기본: 켜짐). 끄면 항상 ANTHROPIC_MODEL_REFINE만 사용
# AI_ENABLE_PREMIUM_MODE=true
# true면 품질 보정(repair) LLM 루프 생략(지연·비용 절감, 엄격 품질 검사는 그대로)
# AI_ENABLE_REFINE_SKIP=true
# AI_LOG_TOKENS=true
# AI_LOG_COST_ESTIMATE=true

# 로컬/스테이징만: mock이면 실제 LLM 호출 없이 고정 샘플로 생성합니다. 운영(production)에서는 무시됩니다.
# 관리자「생성 로그」의 엔진 열에서 목업(mock) vs 실API(Claude/GPT)를 구분할 수 있습니다.
# AI_MODE=mock

# 데이터 저장 경로 (기본값: ./data). 파일 기반은 단가/설정 등에만 사용. 견적 이력은 DB 사용.
DATA_DIR=./data

# ── DB (Neon Postgres, 운영 필수) ──
# 견적/히스토리·관리자「생성 로그」(generation_runs)는 DB에 저장됩니다. 없으면 생성은 되어도 로그 행이 쌓이지 않습니다.
# https://neon.tech 에서 프로젝트 생성 후 Connection string 복사
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 아이디·비밀번호 회원가입/로그인 (결제 테스트용). 아래 중 하나로 켜면 됩니다.
# - 서버에서만: ENABLE_EMAIL_PASSWORD_AUTH=1
# - next start / Vercel(production 빌드)에서 화면·Provider 모두 켜려면(권장):
# NEXT_PUBLIC_ENABLE_CREDENTIAL_AUTH=1
# ENABLE_EMAIL_PASSWORD_AUTH=1
# - 소셜 로그인만 강제하려면(운영 전환용):
# AUTH_SOCIAL_ONLY=1
# NEXT_PUBLIC_AUTH_SOCIAL_ONLY=1

# ── 결제 (토스페이먼츠, live 모드 시 필수) ──
# mock: 결제 없이 DB에만 구독 반영. live: 실제 토스페이먼츠 결제 + 웹훅 반영
BILLING_MODE=mock
# live 시 아래 변수 필요 (토스페이먼츠 개발자센터에서 발급)
TOSS_PAYMENTS_SECRET_KEY=test_sk_...
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=test_ck_...
# 토스 웹훅 검증(권장): true/1 로 켜면 웹훅 수신 시 토스 API로 paymentKey를 조회해 교차 검증합니다.
TOSS_PAYMENTS_WEBHOOK_VERIFY=false
# 결제/리다이렉트 기준 URL (미설정 시 NEXTAUTH_URL·VERCEL_URL 사용)
NEXT_PUBLIC_APP_URL=https://www.planic.cloud
